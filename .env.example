# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Fuseki
# NOTE: `fuseki` is the Docker-network hostname and only resolves INSIDE the
# compose stack (e.g. the flask container). For host-side tooling such as
# `make load-fuseki` run from your terminal, use http://localhost:3030 — or
# avoid the mismatch entirely with `make load-fuseki-docker`, which runs the
# loader inside the container where `fuseki` resolves.
FUSEKI_BASE_URL=http://fuseki:3030
FUSEKI_DATASET=semantic-platform
FUSEKI_QUERY_ENDPOINT=http://fuseki:3030/semantic-platform/query
FUSEKI_UPDATE_ENDPOINT=http://fuseki:3030/semantic-platform/update

# Optional credentials; do not commit real secrets. The bundled dev Fuseki opens
# its endpoints (docker/fuseki/shiro.ini) so no credentials are required locally.
# Against an authenticated Fuseki, set a username AND password (the client only
# authenticates when both are present); FUSEKI_ADMIN_PASSWORD alone now defaults
# the username to `admin`.
FUSEKI_USERNAME=
FUSEKI_PASSWORD=
FUSEKI_ADMIN_PASSWORD=

# Source materialization (drop-in R2RML -> RDF -> Fuseki)
# Leave SOURCE_DATABASE_URL unset for the self-contained mode (mappings/sql/*.sql
# loaded into in-memory SQLite). Set it to map against a live data platform, e.g.
# SOURCE_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/db
SOURCE_DATABASE_URL=
# Optional: override the relational source files used in self-contained mode
# (comma-separated). Defaults to every mappings/sql/*.sql file (schema first).
MATERIALIZE_SQL_FILES=
# Optional path overrides
MAPPINGS_R2RML_DIR=
MAPPINGS_SQL_DIR=
OUTPUT_DIR=

# ---------------------------------------------------------------------------
# External integration (OPTIONAL) — keep COMMENTED OUT for a fully
# self-contained solution.
#
# Leaving everything below commented means: the relational source is in-memory
# SQLite built from mappings/sql/*.sql, and Fuseki is optional/local. Uncomment
# and fill in to materialize from an EXTERNAL data warehouse (e.g. Snowflake)
# and serve into an EXTERNAL Apache Jena/Fuseki.
# ---------------------------------------------------------------------------

# External data warehouse — Snowflake example.
# Requires the SQLAlchemy Snowflake driver: pip install "snowflake-sqlalchemy".
# When set, SOURCE_DATABASE_URL overrides the self-contained SQLite source and
# each mapping's rr:logicalTable query runs directly against the warehouse.
# SOURCE_DATABASE_URL=snowflake://USER:PASSWORD@ACCOUNT/DATABASE/SCHEMA?warehouse=WAREHOUSE&role=ROLE

# External Apache Jena / Fuseki — point the existing FUSEKI_* settings at the
# remote server to push and serve materialized graphs there. Uncomment to
# override the local defaults above.
# FUSEKI_BASE_URL=https://jena.example.org:3030
# FUSEKI_DATASET=semantic-platform
# FUSEKI_USERNAME=
# FUSEKI_PASSWORD=

# LLM provider for the agent assist and the modelling studio chat.
#   auto   — RECOMMENDED for the UI: uses Anthropic when ANTHROPIC_API_KEY is set,
#            else a reachable local Ollama, else the offline local model. Makes
#            Anthropic and Ollama both first-class without breaking offline use.
#   local  (default for headless/CI) — free, OFFLINE, deterministic model.
LLM_PROVIDER=local
LLM_MODEL=
# The setup UI (/setup/models) persists this choice to WORKSPACE_ROOT; env vars
# set here always take precedence over the UI selection.
#   ollama — a real local LLM served by the bundled container. Start it with
#            `make docker-up-llm` (docker compose --profile llm up -d), then
#            `docker exec semantic-platform-ollama ollama pull llama3.2`.
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
#
# EXTERNAL LLM providers (OPTIONAL) — third-party cloud APIs; require credentials:
#   Anthropic (requires: pip install anthropic)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-opus-4-8
#   OpenAI (requires: pip install openai)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# LLM_MODEL=gpt-4o-mini

# Governed conversational authoring / modelling studio (ADR-0016).
# Generated domain files are written into per-domain git repos cloned under
# WORKSPACE_ROOT (never the platform's own rdf/ tree), reviewed via Pull Request.
WORKSPACE_ROOT=./workspace
# Per-domain push/PR auth: name the env var holding a token in Settings → Domain
# Repos (e.g. DOMAIN_GIT_TOKEN), then set it here. Without a token, the studio
# commits locally and gives you a compare link to open the PR manually.
# DOMAIN_GIT_TOKEN=
# CHAT_AGENT_ID=semantic-context-agent  # approved agent used for read-only "ask this view"
