# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Fuseki — three per-role datasets (ADR-0017)
# Storage is split into three roles, each an independently placeable Fuseki dataset:
#   system   — the platform's own model (ontology/governance/reasoning/...); stays local
#   agents   — agent registry/memory/observations + PROV-O lineage (local or remote)
#   business — domain/reference/instance data (local or remote)
# NOTE: `fuseki` is the Docker-network hostname and only resolves INSIDE the compose
# stack. For host-side tooling such as `make load-fuseki`, use http://localhost:3030 —
# or use `make load-fuseki-docker`, which runs inside the container.
#
# Per-role container topology (ADR-0019): the bundled stack runs ONE Jena container per
# role — fuseki-system, fuseki-agents, fuseki-business — each serving its own dataset.
# FUSEKI_BASE_URL is the SHARED default base URL (points at the system container); any
# role whose own FUSEKI_<ROLE>_BASE_URL is unset falls back to it.
FUSEKI_BASE_URL=http://fuseki-system:3030
# Legacy single-dataset name; used as the system dataset's default.
FUSEKI_DATASET=semantic-platform
# Per-role dataset names (defaults shown).
FUSEKI_SYSTEM_DATASET=semantic-platform
FUSEKI_AGENTS_DATASET=semantic-platform-agents
FUSEKI_BUSINESS_DATASET=semantic-platform-business
# Per-role base URLs — default to each role's bundled container. Override one to place
# that role on a different / remote Jena, independently of the others, e.g.
# FUSEKI_BUSINESS_BASE_URL=https://jena.example.org:3030
FUSEKI_SYSTEM_BASE_URL=http://fuseki-system:3030
FUSEKI_AGENTS_BASE_URL=http://fuseki-agents:3030
FUSEKI_BUSINESS_BASE_URL=http://fuseki-business:3030
# Host-side published ports for the three Jena containers (override on conflict).
FUSEKI_PORT=3030
FUSEKI_AGENTS_PORT=3031
FUSEKI_BUSINESS_PORT=3032

# Optional credentials; do not commit real secrets. The bundled dev Fuseki opens
# its endpoints (docker/fuseki/shiro.ini) so no credentials are required locally.
# Against an authenticated Fuseki, set a username AND password (the client only
# authenticates when both are present); FUSEKI_ADMIN_PASSWORD alone defaults the
# username to `admin`. These apply to every role unless overridden per role with
# FUSEKI_<ROLE>_USERNAME / FUSEKI_<ROLE>_PASSWORD.
FUSEKI_USERNAME=
FUSEKI_PASSWORD=
FUSEKI_ADMIN_PASSWORD=

# Source materialization (drop-in R2RML -> RDF -> Fuseki) — per-role warehouses (ADR-0017)
# A mapping's map:targetGraph selects its role, which selects BOTH the warehouse it reads
# from and the dataset it is served to. Business and agents each have their own source;
# system has none (it is authored from rdf/ files).
#
# In the bundled stack (ADR-0019) each warehouse-having role gets its OWN Postgres
# container by default: postgres-business (seeded with mappings/sql/*) and postgres-agents
# (empty). The flask container wires SOURCE_BUSINESS/AGENTS_DATABASE_URL at them
# automatically. Leave these blank to use that default; set one to point a role at an
# external warehouse instead, e.g.
# SOURCE_BUSINESS_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/db
# To run host-side (no containers) self-contained on SQLite, leave ALL three blank.
SOURCE_DATABASE_URL=
SOURCE_BUSINESS_DATABASE_URL=
SOURCE_AGENTS_DATABASE_URL=
# Per-role Postgres settings for the bundled warehouses (shared user/password).
POSTGRES_USER=semantic
POSTGRES_PASSWORD=semantic
POSTGRES_BUSINESS_DB=semantic_platform_business
POSTGRES_AGENTS_DB=semantic_platform_agents
POSTGRES_PORT=5432
POSTGRES_AGENTS_PORT=5433
# Optional: override the relational source files per role used in self-contained mode
# (comma-separated). Defaults to every mappings/sql/*.sql file (schema first).
MATERIALIZE_SQL_FILES=
MATERIALIZE_BUSINESS_SQL_FILES=
MATERIALIZE_AGENTS_SQL_FILES=
# Optional path overrides (per-role SQL dirs fall back to MAPPINGS_SQL_DIR).
MAPPINGS_R2RML_DIR=
MAPPINGS_SQL_DIR=
MAPPINGS_BUSINESS_SQL_DIR=
MAPPINGS_AGENTS_SQL_DIR=
OUTPUT_DIR=

# ---------------------------------------------------------------------------
# External integration (OPTIONAL) — keep COMMENTED OUT for a fully
# self-contained solution.
#
# Leaving everything below commented means: the relational source is in-memory
# SQLite built from mappings/sql/*.sql, and Fuseki is optional/local. Uncomment
# and fill in to materialize from an EXTERNAL data warehouse (e.g. Snowflake)
# and serve into an EXTERNAL Apache Jena/Fuseki.
# ---------------------------------------------------------------------------

# External data warehouse — Snowflake example.
# Requires the SQLAlchemy Snowflake driver: pip install "snowflake-sqlalchemy".
# When set, SOURCE_DATABASE_URL overrides the self-contained SQLite source and
# each mapping's rr:logicalTable query runs directly against the warehouse.
# SOURCE_DATABASE_URL=snowflake://USER:PASSWORD@ACCOUNT/DATABASE/SCHEMA?warehouse=WAREHOUSE&role=ROLE

# External Apache Jena / Fuseki — place a role remotely WITHOUT moving the others.
# Example: keep system local but read+serve business from a remote warehouse + Jena.
# SOURCE_BUSINESS_DATABASE_URL=snowflake://USER:PASSWORD@ACCOUNT/DATABASE/SCHEMA?warehouse=WAREHOUSE&role=ROLE
# FUSEKI_BUSINESS_BASE_URL=https://jena.example.org:3030
# FUSEKI_BUSINESS_USERNAME=
# FUSEKI_BUSINESS_PASSWORD=
# To move EVERY role to one remote Jena, set the shared FUSEKI_BASE_URL instead:
# FUSEKI_BASE_URL=https://jena.example.org:3030
# FUSEKI_USERNAME=
# FUSEKI_PASSWORD=

# LLM provider for the agent assist and the modelling studio chat.
#   auto   — RECOMMENDED for the UI: uses Anthropic when ANTHROPIC_API_KEY is set,
#            else a reachable local Ollama, else the offline local model. Makes
#            Anthropic and Ollama both first-class without breaking offline use.
#   local  (default for headless/CI) — free, OFFLINE, deterministic model.
LLM_PROVIDER=local
LLM_MODEL=
# The setup UI (/setup/models) persists this choice to WORKSPACE_ROOT; env vars
# set here always take precedence over the UI selection.
#   ollama — a real local LLM served by the bundled container. Start it with
#            `make docker-up-llm` (docker compose --profile llm up -d), then
#            `docker exec semantic-platform-ollama ollama pull llama3.2`.
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
#
# EXTERNAL LLM providers (OPTIONAL) — third-party cloud APIs; require credentials:
#   Anthropic (requires: pip install anthropic)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-opus-4-8
#   OpenAI (requires: pip install openai)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# LLM_MODEL=gpt-4o-mini

# Governed conversational authoring / modelling studio (ADR-0016).
# Generated domain files are written into per-domain git repos cloned under
# WORKSPACE_ROOT (never the platform's own rdf/ tree), reviewed via Pull Request.
WORKSPACE_ROOT=./workspace
# Per-domain push/PR auth: name the env var holding a token in Settings → Domain
# Repos (e.g. DOMAIN_GIT_TOKEN), then set it here. Without a token, the studio
# commits locally and gives you a compare link to open the PR manually.
# DOMAIN_GIT_TOKEN=
# CHAT_AGENT_ID=semantic-context-agent  # approved agent used for read-only "ask this view"
