# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Fuseki
FUSEKI_BASE_URL=http://fuseki:3030
FUSEKI_DATASET=semantic-platform
FUSEKI_QUERY_ENDPOINT=http://fuseki:3030/semantic-platform/query
FUSEKI_UPDATE_ENDPOINT=http://fuseki:3030/semantic-platform/update

# Optional credentials; do not commit real secrets.
FUSEKI_USERNAME=
FUSEKI_PASSWORD=
FUSEKI_ADMIN_PASSWORD=

# Source materialization (drop-in R2RML -> RDF -> Fuseki)
# Leave SOURCE_DATABASE_URL unset for the self-contained mode (mappings/sql/*.sql
# loaded into in-memory SQLite). Set it to map against a live data platform, e.g.
# SOURCE_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/db
SOURCE_DATABASE_URL=
# Optional: override the relational source files used in self-contained mode
# (comma-separated). Defaults to every mappings/sql/*.sql file (schema first).
MATERIALIZE_SQL_FILES=
# Optional path overrides
MAPPINGS_R2RML_DIR=
MAPPINGS_SQL_DIR=
OUTPUT_DIR=
