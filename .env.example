# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Fuseki
FUSEKI_BASE_URL=http://fuseki:3030
FUSEKI_DATASET=semantic-platform
FUSEKI_QUERY_ENDPOINT=http://fuseki:3030/semantic-platform/query
FUSEKI_UPDATE_ENDPOINT=http://fuseki:3030/semantic-platform/update

# Optional credentials; do not commit real secrets.
FUSEKI_USERNAME=
FUSEKI_PASSWORD=
FUSEKI_ADMIN_PASSWORD=

# Installed Apache Jena / external Fuseki option
# Use when Fuseki/Jena is installed on the host or provided by another environment.
SEMANTIC_PLATFORM_RUNTIME=docker
JENA_HOME=
JENA_BIN=
FUSEKI_PORT=3030
# For a containerized Flask app talking to host Fuseki, override FUSEKI_BASE_URL with host.docker.internal.
