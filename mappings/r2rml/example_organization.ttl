@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sp: <https://example.org/semantic-platform/core#> .
@prefix map: <https://example.org/semantic-platform/mappings#> .
@prefix gov: <https://example.org/semantic-platform/governance#> .

<https://example.org/mapping/organization-r2rml>
    a rr:TriplesMap, map:Mapping ;
    rr:logicalTable [ rr:tableName "organization" ] ;
    rr:subjectMap [ rr:template "https://example.org/resource/organization/{organization_id}" ; rr:class sp:Entity ; rr:graph <urn:graph:reference> ] ;
    rr:predicateObjectMap [ rr:predicate sp:identifier ; rr:objectMap [ rr:column "organization_id" ; rr:datatype xsd:string ] ] ;
    rr:predicateObjectMap [ rr:predicate sp:name ; rr:objectMap [ rr:column "organization_name" ; rr:datatype xsd:string ] ] ;
    rr:predicateObjectMap [ rr:predicate sp:status ; rr:objectMap [ rr:template "https://example.org/status/{status_code}" ; rr:termType rr:IRI ] ] ;
    map:sourcedFrom <https://example.org/source-dataset/organizations> ;
    map:targetGraph <urn:graph:reference> ;
    map:version "1.0.0" ;
    gov:hasOwner gov:platformOwner ;
    gov:hasSteward gov:platformSteward .
