PREFIX exec: <https://example.org/semantic-platform/execution#>
PREFIX orch: <https://example.org/semantic-platform/orchestration#>
SELECT ?approval ?subject ?status WHERE {
  { ?approval a exec:Approval ; exec:approvesAction ?subject ; exec:approvalStatus ?status . }
  UNION
  { ?approval a orch:ApprovalGate ; orch:approvalSubject ?subject ; orch:approvalStatus ?status . }
}
ORDER BY ?approval
