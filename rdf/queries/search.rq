PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dcterms: <http://purl.org/dc/terms/>
SELECT ?resource ?label ?description
WHERE {
  ?resource ?p ?o .
  OPTIONAL { ?resource rdfs:label ?label }
  OPTIONAL { ?resource dcterms:description ?description }
  FILTER(CONTAINS(LCASE(STR(?resource)), LCASE(?term)) || CONTAINS(LCASE(STR(?label)), LCASE(?term)) || CONTAINS(LCASE(STR(?description)), LCASE(?term)))
}
