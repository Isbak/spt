PREFIX aggov: <https://example.org/semantic-platform/agent-governance#>
PREFIX agent: <https://example.org/semantic-platform/agents#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?agent ?label ?version ?status WHERE {
  ?agent a agent:Agent ; rdfs:label ?label ; owl:versionInfo ?version ; aggov:approvalStatus ?status .
}
ORDER BY ?label
