PREFIX agent: <https://example.org/semantic-platform/agents#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?agent ?label ?capabilityLabel WHERE {
  ?agent a agent:Agent ; rdfs:label ?label ; agent:hasCapability ?capability .
  ?capability rdfs:label ?capabilityLabel .
}
ORDER BY ?label ?capabilityLabel
