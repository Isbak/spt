@prefix ex: <https://example.org/semantic-platform/provenance#> .
@prefix gov: <https://example.org/semantic-platform/governance#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/semantic-platform/provenance>
    a owl:Ontology ;
    dcterms:title "Semantic Platform Provenance Vocabulary" ;
    dcterms:description "PROV-O-compatible provenance patterns and generic sample records for platform activities." ;
    dcterms:created "2026-06-10"^^xsd:date ;
    dcterms:modified "2026-06-10"^^xsd:date ;
    dcterms:creator "Semantic Platform" ;
    dcterms:publisher "Semantic Platform" ;
    owl:versionInfo "0.2.0" .

prov:Entity rdfs:label "PROV entity" .
prov:Activity rdfs:label "PROV activity" .
prov:Agent rdfs:label "PROV agent" .
prov:wasGeneratedBy rdfs:label "was generated by" .
prov:wasDerivedFrom rdfs:label "was derived from" .
prov:wasAssociatedWith rdfs:label "was associated with" .
prov:startedAtTime rdfs:label "started at time" .
prov:endedAtTime rdfs:label "ended at time" .

ex:platformAgent a prov:Agent ; rdfs:label "Semantic platform agent" .
ex:sourceDataset a prov:Entity, gov:Dataset ; rdfs:label "Source dataset import entity" .
ex:transformedDataset a prov:Entity, gov:Dataset ; rdfs:label "Transformed dataset entity" ; prov:wasDerivedFrom ex:sourceDataset .
ex:loadedGraph a prov:Entity ; rdfs:label "Loaded graph entity" ; prov:wasDerivedFrom ex:transformedDataset ; prov:wasGeneratedBy ex:graphLoadActivity .

ex:sourceDatasetImportActivity
    a prov:Activity ;
    rdfs:label "Source dataset import activity" ;
    prov:startedAtTime "2026-06-10T00:00:00Z"^^xsd:dateTime ;
    prov:endedAtTime "2026-06-10T00:01:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith ex:platformAgent .

ex:transformationActivity
    a prov:Activity ;
    rdfs:label "Transformation activity" ;
    prov:startedAtTime "2026-06-10T00:02:00Z"^^xsd:dateTime ;
    prov:endedAtTime "2026-06-10T00:03:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith ex:platformAgent .

ex:graphLoadActivity
    a prov:Activity ;
    rdfs:label "Graph load activity" ;
    prov:startedAtTime "2026-06-10T00:04:00Z"^^xsd:dateTime ;
    prov:endedAtTime "2026-06-10T00:05:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith ex:platformAgent .

ex:rdfValidationActivity
    a prov:Activity ;
    rdfs:label "RDF validation activity" ;
    prov:startedAtTime "2026-06-10T00:06:00Z"^^xsd:dateTime ;
    prov:endedAtTime "2026-06-10T00:07:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith ex:platformAgent .

ex:sourceDataset prov:wasGeneratedBy ex:sourceDatasetImportActivity .
ex:transformedDataset prov:wasGeneratedBy ex:transformationActivity .
