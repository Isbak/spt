@prefix adv: <https://example.org/semantic-platform/advisory#> .
@prefix aggov: <https://example.org/semantic-platform/agent-governance#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Illustrative advisory record. "Assignment" candidates are an example only; the advisory
# capability is domain-neutral and works over any governed candidate type and criteria.
adv:example-advisory a adv:Advisory ;
  rdfs:label "Example assignment advisory" ;
  dcterms:description "Illustrative governed advisory ranking candidate assignments against weighted criteria. Advisory only; requires human approval before execution." ;
  owl:versionInfo "0.1.0" ;
  aggov:owner "Semantic Platform Core Team" ;
  aggov:steward "Semantic Platform Steward" ;
  aggov:approvalStatus "Approved" ;
  adv:objective "Recommend the best assignment for a service job" ;
  adv:hasCriterion adv:criterion-proximity, adv:criterion-skill-match, adv:criterion-availability ;
  adv:recommends adv:example-recommendation .

adv:criterion-proximity a adv:Criterion ;
  rdfs:label "Proximity" ;
  adv:criterionWeight 2.0 ;
  adv:criterionDirection "minimize" .

adv:criterion-skill-match a adv:Criterion ;
  rdfs:label "Skill match" ;
  adv:criterionWeight 3.0 ;
  adv:criterionDirection "maximize" .

adv:criterion-availability a adv:Criterion ;
  rdfs:label "Availability" ;
  adv:criterionWeight 1.0 ;
  adv:criterionDirection "maximize" .

adv:example-recommendation a adv:Recommendation ;
  rdfs:label "Recommended assignment" ;
  adv:score 0.78 ;
  adv:rationale "Highest weighted score across skill match, proximity, and availability; pending human approval." .
