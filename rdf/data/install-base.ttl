@prefix ib: <https://example.org/semantic-platform/install-base#> .
@prefix sp: <https://example.org/semantic-platform/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# Example drop-in data/ontology file. Placed in rdf/data/, it is automatically
# loaded by load_graph, syntax-checked by `make validate`, and SHACL-validated
# against rdf/shapes/install_base_shapes.ttl. It defines the install-base
# vocabulary that the matching R2RML mapping populates from a relational source.
# It is illustrative only and bakes no domain assumptions into core modules.

ib:InstallBaseItem
    a owl:Class ;
    rdfs:label "Install base item" ;
    rdfs:comment "A deployed/installed item tracked in an install base." .

ib:product a owl:DatatypeProperty ; rdfs:label "product" ; rdfs:domain ib:InstallBaseItem .
ib:location a owl:DatatypeProperty ; rdfs:label "location" ; rdfs:domain ib:InstallBaseItem .
ib:status a owl:DatatypeProperty ; rdfs:label "status" ; rdfs:domain ib:InstallBaseItem .

# A seed instance authored directly (as opposed to materialized from the source),
# demonstrating that dropped data conforms to the install-base SHACL shape.
ib:item-seed
    a ib:InstallBaseItem ;
    sp:identifier "IB-SEED" ;
    rdfs:label "Reference install base item" ;
    ib:product "Gateway X100" ;
    ib:location "Reference Site" ;
    ib:status "active" ;
    dcterms:description "Authored seed item used to demonstrate SHACL coverage." .
