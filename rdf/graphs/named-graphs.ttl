@prefix sp: <https://example.org/semantic-platform/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<urn:semantic-platform:graph:ontology>
    a sp:NamedGraph ;
    sp:identifier "urn:semantic-platform:graph:ontology" ;
    dcterms:title "Ontology graph" .

<urn:semantic-platform:graph:reference>
    a sp:NamedGraph ;
    sp:identifier "urn:semantic-platform:graph:reference" ;
    dcterms:title "Reference vocabulary graph" .

<urn:semantic-platform:graph:data>
    a sp:NamedGraph ;
    sp:identifier "urn:semantic-platform:graph:data" ;
    dcterms:title "Example data graph" .

<urn:semantic-platform:graph:reasoning>
    a sp:NamedGraph ;
    sp:identifier "urn:graph:reasoning" ;
    dcterms:title "Reasoning graph" .

<urn:semantic-platform:graph:inferred>
    a sp:NamedGraph ;
    sp:identifier "urn:graph:inferred" ;
    dcterms:title "Inferred graph" .

<urn:semantic-platform:graph:validation>
    a sp:NamedGraph ;
    sp:identifier "urn:graph:validation" ;
    dcterms:title "Validation graph" .
