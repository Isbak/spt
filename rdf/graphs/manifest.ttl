@prefix graph: <urn:graph:> .
@prefix gov: <https://example.org/semantic-platform/governance#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<urn:graph:ontology> a gov:GraphAsset ; rdfs:label "Ontology graph" ; dcterms:description "Authoritative ontology and schema definitions." ; gov:hasOwner gov:platformOwner ; gov:hasSteward gov:platformSteward ; gov:hasClassification gov:internalClassification ; gov:hasLifecycleStatus gov:active ; gov:intendedUse "Manage domain-neutral ontology assets." ; gov:hasAllowedWritePattern gov:controlledReplace .
<urn:graph:reference> a gov:GraphAsset ; rdfs:label "Reference graph" ; dcterms:description "Reference vocabularies and controlled terms." ; gov:hasOwner gov:platformOwner ; gov:hasSteward gov:platformSteward ; gov:hasClassification gov:internalClassification ; gov:hasLifecycleStatus gov:active ; gov:intendedUse "Manage stable reference data." ; gov:hasAllowedWritePattern gov:controlledReplace .
<urn:graph:masterdata> a gov:GraphAsset ; rdfs:label "Master data graph" ; dcterms:description "Curated master data resources." ; gov:hasOwner gov:platformOwner ; gov:hasSteward gov:platformSteward ; gov:hasClassification gov:internalClassification ; gov:hasLifecycleStatus gov:active ; gov:intendedUse "Manage shared master data resources." ; gov:hasAllowedWritePattern gov:controlledReplace .
<urn:graph:transactional> a gov:GraphAsset ; rdfs:label "Transactional graph" ; dcterms:description "Event and transaction-oriented RDF records." ; gov:hasOwner gov:platformOwner ; gov:hasSteward gov:platformSteward ; gov:hasClassification gov:internalClassification ; gov:hasLifecycleStatus gov:active ; gov:intendedUse "Capture append-oriented operational records." ; gov:hasAllowedWritePattern gov:appendOnly .
<urn:graph:provenance> a gov:GraphAsset ; rdfs:label "Provenance graph" ; dcterms:description "PROV-O records for semantic platform activities." ; gov:hasOwner gov:platformOwner ; gov:hasSteward gov:platformSteward ; gov:hasClassification gov:internalClassification ; gov:hasLifecycleStatus gov:active ; gov:intendedUse "Trace RDF generation, validation, and transformation history." ; gov:hasAllowedWritePattern gov:appendOnly .
<urn:graph:governance> a gov:GraphAsset ; rdfs:label "Governance graph" ; dcterms:description "Ownership, stewardship, classification, policy, and lifecycle metadata." ; gov:hasOwner gov:platformOwner ; gov:hasSteward gov:platformSteward ; gov:hasClassification gov:internalClassification ; gov:hasLifecycleStatus gov:active ; gov:intendedUse "Manage governance metadata for semantic assets." ; gov:hasAllowedWritePattern gov:controlledReplace .
<urn:graph:integration> a gov:GraphAsset ; rdfs:label "Integration graph" ; dcterms:description "Integration staging records used by platform data flows." ; gov:hasOwner gov:platformOwner ; gov:hasSteward gov:platformSteward ; gov:hasClassification gov:internalClassification ; gov:hasLifecycleStatus gov:active ; gov:intendedUse "Stage integration-ready semantic records." ; gov:hasAllowedWritePattern gov:appendOnly .
<urn:graph:sandbox> a gov:GraphAsset ; rdfs:label "Sandbox graph" ; dcterms:description "Temporary experimentation graph for non-authoritative assets." ; gov:hasOwner gov:platformOwner ; gov:hasSteward gov:platformSteward ; gov:hasClassification gov:internalClassification ; gov:hasLifecycleStatus gov:draft ; gov:intendedUse "Support isolated experimentation without authoritative writes." ; gov:hasAllowedWritePattern gov:controlledReplace .
<urn:graph:reasoning> a gov:GraphAsset ; rdfs:label "Reasoning graph" ; dcterms:description "Reasoning metadata, inference explanations, and execution provenance." ; gov:hasOwner gov:platformOwner ; gov:hasSteward gov:platformSteward ; gov:hasClassification gov:internalClassification ; gov:hasLifecycleStatus gov:active ; gov:intendedUse "Store reasoning metadata without mixing it into ontology graphs." ; gov:hasAllowedWritePattern gov:appendOnly .
<urn:graph:inferred> a gov:GraphAsset ; rdfs:label "Inferred graph" ; dcterms:description "Inferred triples generated by the Semantic Reasoning Layer." ; gov:hasOwner gov:platformOwner ; gov:hasSteward gov:platformSteward ; gov:hasClassification gov:internalClassification ; gov:hasLifecycleStatus gov:active ; gov:intendedUse "Store inferred assertions separately from authoritative ontology graphs." ; gov:hasAllowedWritePattern gov:controlledReplace .
<urn:graph:validation> a gov:GraphAsset ; rdfs:label "Validation graph" ; dcterms:description "Semantic consistency and validation results." ; gov:hasOwner gov:platformOwner ; gov:hasSteward gov:platformSteward ; gov:hasClassification gov:internalClassification ; gov:hasLifecycleStatus gov:active ; gov:intendedUse "Store consistency reports and reasoning validation results." ; gov:hasAllowedWritePattern gov:appendOnly .
