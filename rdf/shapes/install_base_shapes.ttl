@prefix ib: <https://example.org/semantic-platform/install-base#> .
@prefix sp: <https://example.org/semantic-platform/core#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# SHACL coverage for dropped install-base data. Without a matching shape,
# custom data passes validation by doing nothing; this shape makes the
# install-base example meaningfully validated.
ib:InstallBaseItemShape
    a sh:NodeShape ;
    sh:targetClass ib:InstallBaseItem ;
    sh:property [
        sh:path sp:identifier ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path ib:status ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .
