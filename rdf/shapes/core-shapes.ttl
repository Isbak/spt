@prefix sp: <https://example.org/semantic-platform/core#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sp:EntityShape
    a sh:NodeShape ;
    sh:targetClass sp:Entity ;
    sh:property [
        sh:path sp:identifier ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sp:name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path sp:status ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path prov:wasGeneratedBy ;
        sh:minCount 1 ;
    ] .

sp:DatasetShape
    a sh:NodeShape ;
    sh:targetClass sp:Dataset ;
    sh:property [
        sh:path prov:wasGeneratedBy ;
        sh:minCount 1 ;
    ] .
